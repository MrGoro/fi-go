{
  "database": {
    "rules": "database.rules.json"
  },
  "functions": {
    "source": "projects/functions",
    "predeploy": [
      "npm run shared:build",
      "rm -rf projects/functions/shared",
      "mkdir -p projects/functions/shared",
      "cp projects/shared/package.json projects/functions/shared/",
      "cp -R projects/shared/dist projects/functions/shared/",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "hosting": {
    "public": "dist/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
